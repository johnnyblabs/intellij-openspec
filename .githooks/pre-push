#!/usr/bin/env bash
#
# pre-push — block homelab-internal references from reaching the PUBLIC GitHub mirror.
#
# Homelab refs (Forgejo issue numbers, Plane IDs, *.geek hostnames, the `johnb`
# username, mcp__homelab tool names) are perfectly fine on the private Forgejo
# `origin`. They must NEVER reach github.com/johnnyblabs/intellij-openspec.
#
# This hook scans the tree being pushed and aborts if any forbidden pattern
# survives outside the allowlisted files that document/implement the rule
# itself. It is a no-op for every remote except GitHub, so normal Forgejo
# pushes are never slowed or blocked.
#
# See CLAUDE.md → "Tracker IDs go in a gitignored .tracking.yaml sidecar" for
# the anti-leak rule this enforces. To clear a block: scrub the reference
# (vendor-neutral wording — "tracker entry", "the linked issue"), or move the
# file out of the tracked tree. A genuinely rule-documenting file can be added
# to ALLOW below.
#
# Activation (per clone): git config core.hooksPath .githooks

set -uo pipefail

remote_url="${2:-}"

# Guard ONLY the public GitHub mirror. Forgejo / any other remote: no-op.
case "$remote_url" in
  *github.com*) ;;
  *) exit 0 ;;
esac

# Forbidden patterns — homelab IDENTIFIERS that must not reach the public mirror.
# These are precise on purpose: the bare CI-platform name "Forgejo" is NOT
# blocked, because the repo openly runs on Forgejo Actions (.forgejo/ is already
# public and is not sensitive). What must never leak is the concrete homelab
# infrastructure: hostnames, the private repo/user path, tracker IDs, MCP names.
#   \.geek / git@geek / geek:222   homelab host (geek, forgejo.geek, plane.geek)
#   johnb[/@]                       homelab user in repo paths / ssh URLs
#   mcp__homelab                    homelab MCP server tool names
#   (OSPEC|OSP|OS)-N                Plane work-item identifiers
#   Forgejo #N                      Forgejo issue references
# NOTE: \b word-boundary is NOT used — git grep's regex engine silently fails to
# match it. Boundaries are expressed as (^|[^[:alnum:]]) instead.
PATTERN='\.geek|git@geek|geek:222|johnb[/@]|mcp__homelab|(^|[^[:alnum:]])(OSPEC|OSP|OS)-[0-9]|Forgejo #'

# Files allowed to mention the patterns: they document or implement the rule.
ALLOW=(':!CLAUDE.md' ':!.githooks')

zero='0000000000000000000000000000000000000000'
status=0

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$zero" ] && continue   # deleting a remote ref — nothing to scan
  hits=$(git grep -nIE "$PATTERN" "$local_sha" -- . "${ALLOW[@]}" 2>/dev/null) || true
  if [ -n "$hits" ]; then
    echo "" >&2
    echo "✖ pre-push BLOCKED: homelab-internal references would reach the public GitHub mirror." >&2
    echo "  ${local_ref} -> ${remote_ref}" >&2
    echo "$hits" | sed 's/^/    /' >&2
    status=1
  fi
done

if [ "$status" -ne 0 ]; then
  echo "" >&2
  echo "Scrub these references (CLAUDE.md anti-leak rule) or move the file out of the tracked tree, then retry." >&2
  echo "Pushes to the private Forgejo 'origin' are unaffected by this hook." >&2
fi

exit "$status"