<idea-plugin>
    <id>com.johnnyb.openspec</id>
    <name>OpenSpec</name>
    <vendor url="https://github.com/fission-ai/openspec" email="openspec@fission.ai">johnnyb</vendor>
    <description><![CDATA[
        <p><b>OpenSpec</b> brings spec-driven development to IntelliJ IDEA. Write specifications first, then implement with confidence — your specs become living documentation that stays connected to your code.</p>

        <p><b>Features:</b></p>
        <ul>
            <li><b>Spec browsing</b> — Tree view of domains, capabilities, and requirements with syntax highlighting</li>
            <li><b>Workflow automation</b> — Init, Propose, Apply, and Archive actions from the IDE</li>
            <li><b>AI-assisted generation</b> — Generate proposals, designs, and specs via Claude, OpenAI, or Gemini</li>
            <li><b>Validation &amp; inspections</b> — Real-time spec format checks and delta spec validation</li>
            <li><b>Coverage panel</b> — See which requirements are referenced in your code at a glance</li>
            <li><b>Gutter markers</b> — <code>@spec</code> annotations in Java link back to their specs</li>
            <li><b>Setup wizard</b> — Guided onboarding for new and existing projects</li>
        </ul>

        <p>Compatible with IntelliJ IDEA 2024.2+. Works with any project that uses the <a href="https://github.com/fission-ai/openspec">OpenSpec</a> framework.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Services -->
        <projectService serviceImplementation="com.johnnyb.openspec.services.OpenSpecProjectService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.ConfigService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.SpecParsingService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.ChangeService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.CliDetectionService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.validation.BuiltInValidator"/>
        <projectService serviceImplementation="com.johnnyb.openspec.scaffolding.ScaffoldingService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.settings.OpenSpecSettings"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.ArtifactOrchestrationService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.ScaffoldingDetectionService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.AiToolDetectionService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.ai.DirectApiService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.DeliveryMethodResolver"/>
        <projectService serviceImplementation="com.johnnyb.openspec.toolwindow.OpenSpecConsoleService"/>
        <projectService serviceImplementation="com.johnnyb.openspec.services.SpecCoverageService"/>

        <!-- Settings -->
        <projectConfigurable instance="com.johnnyb.openspec.settings.OpenSpecConfigurable"
                             id="com.johnnyb.openspec.settings"
                             displayName="OpenSpec"
                             parentId="tools"/>

        <!-- Startup -->
        <postStartupActivity implementation="com.johnnyb.openspec.services.OpenSpecProjectService$StartupDetection"/>

        <!-- Notifications -->
        <notificationGroup id="OpenSpec.Workflow" displayType="BALLOON"/>
        <notificationGroup id="OpenSpec.Generation" displayType="BALLOON"/>
        <notificationGroup id="OpenSpec.Validation" displayType="BALLOON"/>
        <notificationGroup id="OpenSpec.System" displayType="STICKY_BALLOON"/>

        <!-- File Types -->
        <fileType name="OpenSpec YAML"
                  implementationClass="com.johnnyb.openspec.filetype.OpenSpecYamlFileType"
                  fieldName="INSTANCE"
                  language="yaml"
                  fileNames=".openspec.yaml"/>

        <!-- Icon Providers -->
        <iconProvider implementation="com.johnnyb.openspec.filetype.OpenSpecIconProvider"/>

        <!-- Tool Window -->
        <toolWindow id="OpenSpec" anchor="right"
                    factoryClass="com.johnnyb.openspec.toolwindow.OpenSpecToolWindowFactory"
                    icon="/icons/openspec.svg"/>

        <!-- Inspections -->
        <localInspection language=""
                         groupName="OpenSpec"
                         shortName="SpecFormatInspection"
                         displayName="Spec format validation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.johnnyb.openspec.validation.SpecFormatInspection"/>
        <localInspection language=""
                         groupName="OpenSpec"
                         shortName="DeltaSpecInspection"
                         displayName="Delta spec validation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.johnnyb.openspec.validation.DeltaSpecInspection"/>
        <localInspection language="yaml"
                         groupName="OpenSpec"
                         shortName="ConfigValidationInspection"
                         displayName="OpenSpec config validation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.johnnyb.openspec.validation.ConfigValidationInspection"/>

        <!-- Annotators -->
        <annotator language="" implementationClass="com.johnnyb.openspec.editor.SpecAnnotator"/>
        <annotator language="" implementationClass="com.johnnyb.openspec.editor.ScenarioAnnotator"/>

        <!-- Line Markers -->
        <codeInsight.lineMarkerProvider language=""
                                         implementationClass="com.johnnyb.openspec.editor.OpenSpecLineMarkerProvider"/>
        <codeInsight.lineMarkerProvider language="JAVA"
                                         implementationClass="com.johnnyb.openspec.editor.SpecRefLineMarkerProvider"/>
    </extensions>

    <actions>
        <!-- Top-level menu bar entry -->
        <group id="OpenSpec.MainMenu" text="OpenSpec" description="OpenSpec workflow actions" popup="true">
            <action id="OpenSpec.Init"
                    class="com.johnnyb.openspec.actions.OpenSpecInitAction"
                    text="Init"
                    description="Initialize OpenSpec in this project"
                    icon="/icons/openspec.svg"/>
            <action id="OpenSpec.Propose"
                    class="com.johnnyb.openspec.actions.OpenSpecProposeAction"
                    text="Propose..."
                    description="Propose a new change"
                    icon="AllIcons.General.Add"/>
            <action id="OpenSpec.Explore"
                    class="com.johnnyb.openspec.actions.ExploreContextAction"
                    text="Explore..."
                    description="Copy project context to clipboard for AI-assisted exploration"/>
            <action id="OpenSpec.Apply"
                    class="com.johnnyb.openspec.actions.OpenSpecApplyAction"
                    text="Apply"
                    description="Apply the current change"/>
            <action id="OpenSpec.Archive"
                    class="com.johnnyb.openspec.actions.OpenSpecArchiveAction"
                    text="Archive"
                    description="Archive the current change"
                    icon="/icons/archive.svg"/>
            <separator/>
            <action id="OpenSpec.Validate"
                    class="com.johnnyb.openspec.actions.OpenSpecValidateAction"
                    text="Validate"
                    description="Validate specs and config"
                    icon="/icons/requirement.svg"/>
            <action id="OpenSpec.List"
                    class="com.johnnyb.openspec.actions.OpenSpecListAction"
                    text="List"
                    description="List specs and changes"
                    icon="/icons/spec.svg"/>
            <separator/>
            <action id="OpenSpec.Refresh"
                    class="com.johnnyb.openspec.actions.OpenSpecRefreshAction"
                    text="Refresh Tree"
                    description="Refresh the OpenSpec tool window"
                    icon="AllIcons.Actions.Refresh"/>
            <action id="OpenSpec.SetupWizard"
                    class="com.johnnyb.openspec.actions.OpenSpecSetupWizardAction"
                    text="Setup Wizard..."
                    description="Run the OpenSpec setup wizard"
                    icon="AllIcons.General.GearPlain"/>
            <add-to-group group-id="MainMenu" anchor="before" relative-to-action="ToolsMenu"/>
        </group>

        <!-- Tool window toolbar actions -->
        <group id="OpenSpec.ToolWindowToolbar">
            <reference ref="OpenSpec.Refresh"/>
            <reference ref="OpenSpec.Validate"/>
            <reference ref="OpenSpec.Propose"/>
            <reference ref="OpenSpec.SetupWizard"/>
        </group>
    </actions>
</idea-plugin>
