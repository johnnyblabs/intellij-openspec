<idea-plugin>
    <id>com.johnnyblabs.openspec</id>
    <name>OpenSpec</name>
    <vendor url="https://openspec.johnnyblabs.com" email="johnboyce@comcast.net">johnnyblabs</vendor>
    <description><![CDATA[
        <p><b>OpenSpec</b> brings spec-driven development to IntelliJ IDEA. Write specifications first, then implement with confidence — your specs become living documentation that stays connected to your code.</p>

        <p><b>Features:</b></p>
        <ul>
            <li><b>Spec browsing</b> — Tree view of domains, capabilities, and requirements with syntax highlighting</li>
            <li><b>Workflow automation</b> — Init, Propose, Apply, and Archive actions from the IDE</li>
            <li><b>AI-assisted generation</b> — Generate proposals, designs, and specs via Claude, OpenAI, or Gemini</li>
            <li><b>Validation &amp; inspections</b> — Real-time spec format checks and delta spec validation</li>
            <li><b>Setup wizard</b> — Guided onboarding for new and existing projects</li>
        </ul>

        <p>Compatible with IntelliJ IDEA 2024.2+. Works with any project that uses the <a href="https://github.com/fission-ai/openspec">OpenSpec</a> framework.</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Services -->
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.OpenSpecProjectService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.ConfigService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.SpecParsingService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.ChangeService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.CliDetectionService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.validation.BuiltInValidator"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.scaffolding.ScaffoldingService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.settings.OpenSpecSettings"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.ArtifactOrchestrationService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.ScaffoldingDetectionService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.AiToolDetectionService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.ai.DirectApiService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.DeliveryMethodResolver"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.toolwindow.OpenSpecConsoleService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.toolwindow.ExplorePanelService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.VerificationService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.SpecSyncService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.SchemaService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.ExploreContextService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.ExplorePromptService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.ComplianceService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.WorkflowProfileService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.services.WorkflowProfileSwitchService"/>
        <projectService serviceImplementation="com.johnnyblabs.openspec.coordination.CoordinationService"/>

        <!-- Status Bar Widgets -->
        <statusBarWidgetFactory id="OpenSpec.ProfileWidget"
                                implementation="com.johnnyblabs.openspec.statusbar.OpenSpecProfileStatusBarWidgetFactory"
                                order="after vcs"/>

        <!-- Settings -->
        <projectConfigurable instance="com.johnnyblabs.openspec.settings.OpenSpecConfigurable"
                             id="com.johnnyblabs.openspec.settings"
                             displayName="OpenSpec"
                             parentId="tools"/>

        <!-- Startup -->
        <postStartupActivity implementation="com.johnnyblabs.openspec.services.OpenSpecProjectService$StartupDetection"/>

        <!-- Notifications -->
        <notificationGroup id="OpenSpec.Workflow" displayType="BALLOON"/>
        <notificationGroup id="OpenSpec.Generation" displayType="BALLOON"/>
        <notificationGroup id="OpenSpec.Validation" displayType="BALLOON"/>
        <notificationGroup id="OpenSpec.System" displayType="STICKY_BALLOON"/>
        <notificationGroup id="OpenSpec.Compliance" displayType="STICKY_BALLOON"/>

        <!-- File Types -->
        <fileType name="OpenSpec YAML"
                  implementationClass="com.johnnyblabs.openspec.filetype.OpenSpecYamlFileType"
                  fieldName="INSTANCE"
                  language="yaml"
                  fileNames=".openspec.yaml"/>

        <!-- Icon Providers -->
        <iconProvider implementation="com.johnnyblabs.openspec.filetype.OpenSpecIconProvider"/>

        <!-- Tool Window -->
        <toolWindow id="OpenSpec" anchor="right"
                    factoryClass="com.johnnyblabs.openspec.toolwindow.OpenSpecToolWindowFactory"
                    icon="/icons/openspec.svg"/>

        <!-- Inspections -->
        <localInspection language=""
                         groupName="OpenSpec"
                         shortName="SpecFormatInspection"
                         displayName="Spec format validation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.johnnyblabs.openspec.validation.SpecFormatInspection"/>
        <localInspection language=""
                         groupName="OpenSpec"
                         shortName="DeltaSpecInspection"
                         displayName="Delta spec validation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.johnnyblabs.openspec.validation.DeltaSpecInspection"/>
        <localInspection language="yaml"
                         groupName="OpenSpec"
                         shortName="ConfigValidationInspection"
                         displayName="OpenSpec config validation"
                         enabledByDefault="true"
                         level="WARNING"
                         implementationClass="com.johnnyblabs.openspec.validation.ConfigValidationInspection"/>

        <!-- Annotators -->
        <annotator language="" implementationClass="com.johnnyblabs.openspec.editor.SpecAnnotator"/>
        <annotator language="" implementationClass="com.johnnyblabs.openspec.editor.ScenarioAnnotator"/>

        <!-- Line Markers -->
        <codeInsight.lineMarkerProvider language=""
                                         implementationClass="com.johnnyblabs.openspec.editor.OpenSpecLineMarkerProvider"/>
    </extensions>

    <actions>
        <!-- Top-level menu bar entry -->
        <group id="OpenSpec.MainMenu" text="OpenSpec" description="OpenSpec workflow actions" popup="true">
            <action id="OpenSpec.Init"
                    class="com.johnnyblabs.openspec.actions.OpenSpecInitAction"
                    text="Init"
                    description="Initialize OpenSpec in this project"
                    icon="/icons/openspec.svg"/>
            <action id="OpenSpec.Propose"
                    class="com.johnnyblabs.openspec.actions.OpenSpecProposeAction"
                    text="Propose..."
                    description="Propose a new change"
                    icon="AllIcons.General.Add"/>
            <action id="OpenSpec.Ff"
                    class="com.johnnyblabs.openspec.actions.OpenSpecFfAction"
                    text="Fast-Forward..."
                    description="Create a change and generate all artifacts in one step"
                    icon="AllIcons.Actions.Lightning"/>
            <action id="OpenSpec.Explore"
                    class="com.johnnyblabs.openspec.actions.ExploreContextAction"
                    text="Explore..."
                    description="Copy project context to clipboard for AI-assisted exploration"/>
            <action id="OpenSpec.Continue"
                    class="com.johnnyblabs.openspec.actions.OpenSpecContinueAction"
                    text="Continue"
                    description="Generate the next ready artifact for the active change"
                    icon="AllIcons.Actions.Resume"/>
            <action id="OpenSpec.Apply"
                    class="com.johnnyblabs.openspec.actions.OpenSpecApplyAction"
                    text="Apply"
                    description="Apply the current change"/>
            <action id="OpenSpec.SyncSpecs"
                    class="com.johnnyblabs.openspec.actions.OpenSpecSyncAction"
                    text="Sync Specs"
                    description="Merge delta specs into main specs with preview"
                    icon="AllIcons.Actions.Diff"/>
            <action id="OpenSpec.Archive"
                    class="com.johnnyblabs.openspec.actions.OpenSpecArchiveAction"
                    text="Archive"
                    description="Archive the current change and update main specs"
                    icon="/icons/archive.svg"/>
            <action id="OpenSpec.BulkArchive"
                    class="com.johnnyblabs.openspec.actions.OpenSpecBulkArchiveAction"
                    text="Bulk Archive..."
                    description="Archive multiple changes at once with conflict detection"
                    icon="AllIcons.Actions.Checked"/>
            <separator/>
            <action id="OpenSpec.Verify"
                    class="com.johnnyblabs.openspec.actions.OpenSpecVerifyAction"
                    text="Verify"
                    description="Verify implementation matches change artifacts"
                    icon="AllIcons.Actions.PreviewDetailsVertically"/>
            <action id="OpenSpec.Validate"
                    class="com.johnnyblabs.openspec.actions.OpenSpecValidateAction"
                    text="Validate"
                    description="Validate changes and specs"
                    icon="/icons/requirement.svg"/>
            <action id="OpenSpec.List"
                    class="com.johnnyblabs.openspec.actions.OpenSpecListAction"
                    text="List"
                    description="List specs and changes"
                    icon="/icons/spec.svg"/>
            <separator/>
            <action id="OpenSpec.Refresh"
                    class="com.johnnyblabs.openspec.actions.OpenSpecRefreshAction"
                    text="Refresh"
                    description="Refresh the OpenSpec tool window"
                    icon="AllIcons.Actions.Refresh"/>
            <action id="OpenSpec.Update"
                    class="com.johnnyblabs.openspec.actions.OpenSpecUpdateAction"
                    text="Update OpenSpec"
                    description="Refresh agent instruction files via openspec update"
                    icon="AllIcons.Actions.Download"/>
            <action id="OpenSpec.ManageTools"
                    class="com.johnnyblabs.openspec.actions.OpenSpecManageToolsAction"
                    text="Manage AI Tools..."
                    description="Add, configure, and update AI tool integrations"
                    icon="AllIcons.General.GearPlain"/>
            <action id="OpenSpec.SetupWizard"
                    class="com.johnnyblabs.openspec.actions.OpenSpecSetupWizardAction"
                    text="Setup Wizard..."
                    description="Run the OpenSpec setup wizard"
                    icon="AllIcons.Actions.IntentionBulb"/>
            <action id="OpenSpec.Feedback"
                    class="com.johnnyblabs.openspec.actions.OpenSpecFeedbackAction"
                    text="Send OpenSpec Feedback..."
                    description="Send feedback to the OpenSpec maintainers via openspec feedback"
                    icon="AllIcons.General.Balloon"/>
            <add-to-group group-id="MainMenu" anchor="before" relative-to-action="ToolsMenu"/>
        </group>

        <!-- Tool window toolbar actions -->
        <group id="OpenSpec.ToolWindowToolbar">
            <reference ref="OpenSpec.Refresh"/>
            <reference ref="OpenSpec.Validate"/>
            <reference ref="OpenSpec.Propose"/>
            <reference ref="OpenSpec.Ff"/>
            <separator/>
            <reference ref="OpenSpec.Verify"/>
            <reference ref="OpenSpec.SyncSpecs"/>
            <reference ref="OpenSpec.BulkArchive"/>
            <reference ref="OpenSpec.Update"/>
            <reference ref="OpenSpec.ManageTools"/>
            <reference ref="OpenSpec.SetupWizard"/>
            <reference ref="OpenSpec.Feedback"/>
        </group>
    </actions>
</idea-plugin>
